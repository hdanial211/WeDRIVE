{
  "app": {
    "name": "WeDRIVE",
    "version": "1.1.17",
    "tagline": "AI-Powered Car Rental System",
    "support_email": "wedrive@support.com",
    "support_phone": "011-10852955",
    "currency": "RM",
    "timezone": "Asia/Kuala_Lumpur",
    "locale": "en-MY"
  },
  "theme": {
    "default": "day",
    "available": ["day", "night"]
  },
  "language": {
    "default": "en",
    "available": ["en", "bm"]
