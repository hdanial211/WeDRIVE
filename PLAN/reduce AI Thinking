## SUPABASE JS CLIENT PATTERNS

```javascript
// Select all
var result = await sb.from('table').select('*');

// Select with filter
var result = await sb.from('table').select('*').eq('col', val).maybeSingle();

// Insert
await sb.from('table').insert({col1: val1});

// Insert and return
var result = await sb.from('table').insert(data).select().single();

// Update
await sb.from('table').update({col: newVal}).eq('id', id);

// Upsert
await sb.from('table').upsert({key: 'main', value: obj});

// Delete
await sb.from('table').delete().eq('id', id);

// Auth login
sb.auth.signInWithPassword({email, password})

// Auth signup
sb.auth.signUp({email, password, options: {data: {full_name: name}}})

// Google OAuth
sb.auth.signInWithOAuth({provider: 'google', options: {redirectTo: url}})

// Get session / user / logout
sb.auth.getSession()
sb.auth.getUser()
sb.auth.signOut()
```

